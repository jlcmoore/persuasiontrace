# copy this to ".env" and fill in your real values
PATH=/opt/continuouspersuasion/env-continuouspersuasion/bin
OPENAI_API_KEY=your-real-openai-key-goes-here
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Vertex Batch (required for Vertex AI batch jobs)
GCS_BUCKET_NAME="my-batch-bucket"
GCS_PATH_SERVICE_ACCOUNT="/path/to/service_account.json"

# Vertex Credentials
GOOGLE_APPLICATION_CREDENTIALS="/path/to/service_account.json"
VERTEXAI_PROJECT="gse-social"
VERTEXAI_LOCATION="global"

# OpenAI / Azure OpenAI
OPENAI_API_KEY="sk-..."

# Anthropic
ANTHROPIC_API_KEY=""

# Together
TOGETHER_API_KEY=""

# Weights & Biases (optional, for local SFT training metrics)
WANDB_API_KEY=""
WANDB_PROJECT="continuouspersuasion"

# Local hosted-vLLM policy endpoint (optional, for local eval against simulated target)
HOSTED_VLLM_API_BASE="http://127.0.0.1:8001/v1"
HOSTED_VLLM_API_KEY="dummy"
